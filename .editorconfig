# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = false
end_of_line = crlf

[*.{MD,md}]
indent_style = space
indent_size = 4

[*.{HTML,html}]
indent_style = tab
indent_size = 2

[*.{CSS,css}]
indent_style = tab
indent_size = 4

[*.{TS,ts}]
indent_style = tab
indent_size = 4

[*.{JS,js}]
indent_style = tab
indent_size = 4

# EOF